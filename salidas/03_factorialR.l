(defun factorial (n)
 (setq factorial_retorno 0)
 (if (= n 1) (progn  (setf factorial_retorno 1)
) (progn  (setf factorial_retorno (* n (factorial (- n 1))))
))
 (princ n)
(princ " ")
(princ factorial_retorno)
 (print " ")
 (return-from factorial factorial_retorno)
)
(defun main ()
 (setq main_resultado 0)
 (setf main_resultado (factorial 7))
 (princ main_resultado)
)
 (main)
